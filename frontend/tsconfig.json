{
  "compileOnSave": false,
  "compilerOptions": {
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve",
    "baseUrl": "./",
    "paths": {
      "@nexago/firebase-config": ["shared/firebase/firebase.config.ts"]
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "typeCheckHostBindings": true,
    "strictTemplates": true
  },
  "files": [],
  "references": [
    {
      "path": "./projects/site/tsconfig.app.json"
    },
    {
      "path": "./projects/site/tsconfig.spec.json"
    },
    {
      "path": "./projects/arena/tsconfig.app.json"
    },
    {
      "path": "./projects/arena/tsconfig.spec.json"
    },
    {
      "path": "./projects/athlete/tsconfig.app.json"
    },
    {
      "path": "./projects/athlete/tsconfig.spec.json"
    }
  ]
}
